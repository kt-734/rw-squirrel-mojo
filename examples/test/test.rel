@@struct @@Test:
    name: String

def @@testFunc() -> List[@@Test]:
    var ret = List[@@Test]()
    ret.append(@@Test { .name = "ex1" })
    return ret^

def main():
    @@{
        var @@localList = @@testFunc()
        for @@l in @@localList:
            print(@@l.name)

        print(@@localList[0].name)
    @@}
